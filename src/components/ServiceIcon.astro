---
/**
 * Icono del servicio: mismo SVG que en el index.
 * Usar el mismo slug en index y en la página del servicio para que la view transition
 * haga morph del icono entre páginas (transition:name="icon-{slug}").
 */
interface Props {
  slug: 'estrategia-digital' | 'publicidad-digital' | 'link-in-bio' | 'redes-sociales' | 'branding' | 'fotografia-video' | 'desarrollo-web';
  /** "card" = estilo index (fondo white/20), "page" = estilo página de servicio */
  variant?: 'card' | 'page';
}

const { slug, variant = 'card' } = Astro.props;

const transitionName = `icon-${slug}`;

const iconPaths: Record<Props['slug'], string | string[]> = {
  'estrategia-digital': 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
  'publicidad-digital': 'M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.583 1.87.88 2.818.075.36.11.73.11 1.09 0 .36-.035.73-.11 1.09-.297.948-.627 1.856-.88 2.818m0-18.36c-.253.962-.583 1.87-.88 2.818-.075.36-.11.73-.11 1.09 0 .36.035.73.11 1.09.297.948.627 1.856.88 2.818M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12c0 .98-.003 1.967-.138 2.932a4.006 4.006 0 01-3.7 3.7 48.657 48.657 0 01-7.324 0 4.006 4.006 0 01-3.7-3.7 47.865 47.865 0 01-.046-.932',
  'link-in-bio': 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244',
  'redes-sociales': 'M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z',
  'branding': 'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.38 3.395a15.995 15.995 0 004.769-2.95m-4.769-4.899a15.98 15.98 0 013.412-2.497m-4.899 4.9a15.98 15.98 0 012.497-3.412',
  'fotografia-video': ['M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z', 'M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z'],
  'desarrollo-web': 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
};

const paths = iconPaths[slug];
const pathArray = Array.isArray(paths) ? paths : [paths];

const wrapperClass = variant === 'card'
  ? 'w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center text-white'
  : 'w-16 h-16 rounded-2xl bg-mauve-100 flex items-center justify-center text-mauve-700';
const iconClass = variant === 'card' ? 'w-7 h-7' : 'w-9 h-9';
---

<div transition:name={transitionName} class={wrapperClass} aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class={iconClass}>
    {pathArray.map((d) => (
      <path stroke-linecap="round" stroke-linejoin="round" d={d} />
    ))}
  </svg>
</div>
